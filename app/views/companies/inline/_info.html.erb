<%= turbo_frame_tag dom_id(company, :info) do %>
    <div class="flex flex-col px-2 py-1 gap-2">
        <%= link_to edit_info_inline_company_path(company), 
            class: "text-sm text-blue-600 hover:text-blue-800", data: {turbo_prefetch: false} do %>
            <span class="font-medium"><%= company.info.present? ? truncate(company.info, length: 25) : '.......' %></span>
        <% end %>
    </div>
<% end %>