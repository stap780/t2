<% insale = local_assigns[:insale] || @insale %>
<%= turbo_frame_tag dom_id(mapping), class: "grid grid-cols-[1fr_1fr_2fr_120px] gap-4 p-4 items-center hover:bg-gray-50 border-t" do %>
  <div class="text-sm font-mono"><%= mapping.insales_custom_status_permalink %></div>
  <div class="text-sm">
    <%= t("insales_order_status_mappings.financial_statuses.#{mapping.insales_financial_status}", default: mapping.insales_financial_status) %>
  </div>
  <div>
    <% if mapping.order_status %>
      <span class="px-2 py-1 text-xs font-medium rounded-full <%= mapping.order_status.color %>">
        <%= mapping.order_status.title %>
      </span>
    <% end %>
  </div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_insale_insales_order_status_mapping_path(insale, mapping), data: { turbo_frame: :offcanvas, turbo_prefetch: false } %>
    <%= link_to_delete insale_insales_order_status_mapping_path(insale, mapping), data: { turbo_method: :delete, turbo_confirm: t("actions.delete") } %>
  </div>
<% end %>
