<%= turbo_frame_tag dom_id(mapping), class: 'grid grid-cols-[50px_140px_1fr_200px_200px_120px] gap-4 p-4 border-t hover:bg-gray-50 items-center' do %>
  <div><%= mapping.id %></div>
  <div class="text-sm text-gray-600">
    <% if mapping.insale %>
      #<%= mapping.insale_id %>
    <% else %>
      <%= t('insales_order_status_mappings.index.any_shop') %>
    <% end %>
  </div>
  <div class="font-mono text-sm"><%= mapping.insales_status_key %></div>
  <div><%= mapping.insales_status_title %></div>
  <div><%= mapping.order_status&.title %></div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_insales_order_status_mapping_path(mapping), data: { turbo_frame: 'offcanvas', turbo_prefetch: false } %>
    <%= link_to_delete insales_order_status_mapping_path(mapping), data: { turbo_method: :delete, turbo_confirm: t('actions.delete') } %>
  </div>
<% end %>
