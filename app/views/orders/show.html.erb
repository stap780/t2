<div class="flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center mb-4 space-x-4">
    <%= link_to_back orders_path %>
    <h1 class="text-xl font-semibold flex items-center gap-2 flex-wrap">
      <%= t(".heading", number: order_display_number(@order)) %>
    </h1>
  </div>
  <div class="ml-auto flex flex-wrap gap-2">
    <% if !@order.moysklad_linked? && @order.source != "moysklad" %>
      <%= button_to t(".export_to_moysklad"), export_to_moysklad_order_path(@order), method: :post,
          class: "px-4 py-2 bg-emerald-600 text-white rounded-md hover:bg-emerald-700 text-sm cursor-pointer",
          data: { turbo_confirm: t(".export_confirm") } %>
    <% end %>
    <% if @order.moysklad_linked? %>
      <%= button_to t(".sync_from_moysklad"), sync_from_moysklad_order_path(@order), method: :post,
          class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700 text-sm cursor-pointer",
          data: { turbo_confirm: t(".sync_from_moysklad_confirm") } %>
    <% end %>
    <% if @order.insales_channel? && @order.insales_order_id.present? %>
      <%= button_to t(".push_to_insales"), push_to_insales_order_path(@order), method: :post,
          class: "px-4 py-2 bg-amber-600 text-white rounded-md hover:bg-amber-700 text-sm cursor-pointer",
          data: { turbo_confirm: t(".push_to_insales_confirm") } %>
    <% end %>
    <% if @order.avito? %>
      <%= button_to t(".refresh_avito_label"), download_avito_label_order_path(@order, force: true), method: :post,
          class: "px-4 py-2 bg-sky-600 text-white rounded-md hover:bg-sky-700 text-sm cursor-pointer",
          data: { turbo_confirm: t(".refresh_avito_label_confirm") } %>
    <% end %>
  </div>
</div>

<div class="flex items-center mb-4 space-x-4">
  <%= order_source_badge(@order) %>
  <%= order_status_badge(@order) %>
  <p class="text-sm text-gray-500 mt-1">
    <%= t(".created_at", time: l(@order.created_at)) %>
    <% if @order.synced_at.present? %>
      · <%= t(".synced_at", time: l(@order.synced_at)) %>
    <% end %>
  </p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2 space-y-4">
    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3"><%= t(".items_heading") %></h2>
      <% if @order_items.any? %>
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b">
              <th class="pb-2 pr-2"><%= t("activerecord.attributes.order_item.title") %></th>
              <th class="pb-2 pr-2"><%= t("activerecord.attributes.order_item.sku") %></th>
              <th class="pb-2 pr-2 text-right"><%= t("activerecord.attributes.order_item.quantity") %></th>
              <th class="pb-2 pr-2 text-right"><%= t("activerecord.attributes.order_item.price") %></th>
              <th class="pb-2 text-right"><%= t(".line_sum") %></th>
            </tr>
          </thead>
          <tbody>
            <% @order_items.each do |item| %>
              <tr class="border-b border-gray-100">
                <td class="py-2 pr-2">
                  <% if item.variant&.product %>
                    <%= link_to item.title.presence || item.variant.product.title,
                        edit_product_path(item.variant.product),
                        class: "text-violet-700 hover:text-violet-900",
                        data: { turbo: false } %>
                  <% else %>
                    <%= item.title.presence || "—" %>
                  <% end %>
                </td>
                <td class="py-2 pr-2 font-mono text-xs text-gray-600"><%= item.sku.presence || "—" %></td>
                <td class="py-2 pr-2 text-right"><%= item.quantity %></td>
                <td class="py-2 pr-2 text-right"><%= number_to_currency(item.price || 0, unit: currency_unit(@order.currency), format: "%n %u") %></td>
                <td class="py-2 text-right font-medium"><%= number_to_currency(item.line_sum, unit: currency_unit(@order.currency), format: "%n %u") %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr>
              <td colspan="4" class="pt-3 text-right text-gray-600"><%= t("activerecord.attributes.order.total_sum") %></td>
              <td class="pt-3 text-right font-semibold"><%= format_order_money(@order) %></td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <p class="text-gray-500"><%= t(".no_items") %></p>
      <% end %>
    </div>

    <% if @order.comments.any? %>
      <div class="bg-white rounded-lg shadow p-5">
        <h2 class="text-sm font-semibold text-gray-700 mb-2"><%= t(".notes_heading") %></h2>
        <ul class="space-y-2 text-sm text-gray-800">
          <% @order.comments.order(created_at: :asc).each do |comment| %>
            <li class="whitespace-pre-wrap"><%= comment.body %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3"><%= t(".client_heading") %></h2>
      <% if @order.client %>
        <dl class="space-y-2 text-sm">
          <div>
            <dt class="text-gray-500"><%= t(".client_name") %></dt>
            <dd>
              <%= link_to order_client_name(@order), client_path(@order.client),
                  class: "text-blue-600 hover:text-blue-800",
                  data: { turbo: false } %>
            </dd>
          </div>
          <% if @order.client.email.present? %>
            <div>
              <dt class="text-gray-500"><%= t("activerecord.attributes.client.email") %></dt>
              <dd><%= @order.client.email %></dd>
            </div>
          <% end %>
          <% if @order.client.phone.present? %>
            <div>
              <dt class="text-gray-500"><%= t("activerecord.attributes.client.phone") %></dt>
              <dd><%= @order.client.phone %></dd>
            </div>
          <% end %>
        </dl>
      <% else %>
        <p class="text-gray-500 text-sm">—</p>
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3"><%= t(".order_details_heading") %></h2>
      <dl class="space-y-2 text-sm">
        <% if @order.avito_marketplace_id.present? %>
          <div>
            <dt class="text-gray-500"><%= t("activerecord.attributes.order.avito_marketplace_id") %></dt>
            <dd class="font-mono text-xs"><%= @order.avito_marketplace_id %></dd>
          </div>
        <% end %>
        <div class="flex my-2">
          <%= link_to t(".open_avito_label"), rails_blob_path(@order.avito_label, disposition: "inline"),
            target: "_blank", rel: "noopener",
            class: "px-4 py-2 bg-slate-100 text-slate-800 rounded-md hover:bg-slate-200 text-sm cursor-pointer" if @order.avito_label.attached?  %>
        </div>
        <div>
          <dt class="text-gray-500"><%= t("activerecord.attributes.order.tracking_number") %></dt>
          <dd class="font-mono text-xs"><%= @order.tracking_number.presence || "—" %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="text-sm font-semibold text-gray-700 mb-3"><%= t(".integrations_heading") %></h2>
      <dl class="space-y-3 text-sm">
        <% if @order.moysklad_linked? %>
          <div>
            <dt class="text-gray-500"><%= t("activerecord.attributes.order.moysklad_order_id") %></dt>
            <dd class="font-mono text-xs break-all">
              <%= link_to @order.moysklad_order_id, moysklad_order_url(@order),
                  target: "_blank", rel: "noopener", class: "text-emerald-700 hover:text-emerald-900" %>
            </dd>
            <% if @order.moysklad_external_code.present? %>
              <dd class="text-xs text-gray-500 mt-1">
                <%= t("activerecord.attributes.order.moysklad_external_code") %>: <%= @order.moysklad_external_code %>
              </dd>
            <% end %>
          </div>
        <% end %>

        <% if @order.avito_order_id.present? %>
          <div>
            <dt class="text-gray-500"><%= t("activerecord.attributes.order.avito_order_id") %></dt>
            <dd class="font-mono text-xs"><%= @order.avito_order_id %></dd>
            <% if @order.avito_status_sent.present? %>
              <dd class="text-xs text-gray-500 mt-1">
                Avito transition: <%= @order.avito_status_sent %>
              </dd>
            <% end %>
          </div>
        <% end %>

        <% if @order.insales_order_id.present? %>
          <div>
            <dt class="text-gray-500"><%= t("activerecord.attributes.order.insales_order_id") %></dt>
            <dd class="font-mono text-xs">
              <% url = insales_order_url(@order) %>
              <% if url %>
                <%= link_to @order.insales_order_id, url, target: "_blank", rel: "noopener",
                    class: "text-blue-700 hover:text-blue-900" %>
              <% else %>
                <%= @order.insales_order_id %>
              <% end %>
            </dd>
            <% if @order.insale %>
              <dd class="text-xs text-gray-500 mt-1"><%= @order.insale.api_link %></dd>
            <% end %>
          </div>
        <% end %>

        <% unless @order.moysklad_linked? || @order.avito_order_id.present? || @order.insales_order_id.present? %>
          <p class="text-gray-500"><%= t(".no_external_ids") %></p>
        <% end %>
      </dl>
    </div>
  </div>
</div>
