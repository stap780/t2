<%= form_with model: mapping, local: true, class: "space-y-4" do |f| %>
  <%= render 'shared/errors', object: mapping %>

  <fieldset>
    <%= f.label :moysklad_state_href, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if @ms_states.present? %>
      <%= f.select :moysklad_state_href,
          options_for_select(
            @ms_states.map { |s| [s[:name], s[:href]] },
            mapping.moysklad_state_href
          ),
          { include_blank: true },
          class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    <% else %>
      <%= f.text_field :moysklad_state_href, class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm",
          placeholder: "https://api.moysklad.ru/api/remap/1.2/entity/customerorder/metadata/states/..." %>
      <p class="text-xs text-gray-500 mt-1"><%= t('moysklad_order_status_mappings.form.state_href_hint') %></p>
    <% end %>
  </fieldset>

  <% if @ms_states.blank? %>
    <fieldset>
      <%= f.label :moysklad_state_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :moysklad_state_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </fieldset>
  <% end %>

  <fieldset>
    <%= f.label :order_status_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :order_status_id, order_status_options_for_select(mapping.order_status_id),
        {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
  </fieldset>

  <div class="flex justify-end">
    <%= f.submit t('actions.save'), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
