<%= turbo_frame_tag dom_id(order_status),
    class: "grid grid-cols-[80px_120px_1fr_80px_100px_200px] gap-4 p-4 border-t hover:bg-gray-50 text-sm min-w-[800px] items-center",
    data: {
      sort_item_id: order_status.id,
      sort_url: sort_order_status_path(order_status)
    } do %>
  <div class="flex items-center gap-1">
    <button type="button" class="js-sort-handle flex items-center justify-center text-blue-400 hover:text-blue-600 rounded p-1 focus:outline-none focus:ring-2 focus:ring-blue-300 cursor-move" title="Перетащить">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 9h14M5 15h14" />
      </svg>
    </button>
    <span class="bg-blue-200 text-blue-800 text-xs font-semibold px-2 py-1 rounded" data-sortable-target="position">
      <%= order_status.position %>
    </span>
  </div>
  <div class="font-mono text-xs text-gray-600"><%= order_status.code %></div>
  <div>
    <%= link_to order_status.title, edit_order_status_path(order_status),
        class: "text-violet-700 hover:text-violet-900 font-medium",
        data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
  </div>
  <div><%= order_status.is_terminal? ? "✓" : "" %></div>
  <div>
    <% if order_status.color.present? %>
      <span class="inline-block w-6 h-6 rounded-full border border-gray-200" style="background-color: <%= order_status.color %>"></span>
    <% end %>
  </div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_order_status_path(order_status), data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
    <%= link_to_delete order_status_path(order_status), data: { turbo_method: :delete, turbo_confirm: t("actions.delete") } %>
  </div>
<% end %>
