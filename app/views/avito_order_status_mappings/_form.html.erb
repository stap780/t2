<% avito = local_assigns[:avito] || @avito %>
<%= form_with model: [avito, mapping], class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: mapping %>
  <fieldset>
    <%= f.label :order_status_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :order_status_id, order_status_options_for_select(mapping.order_status_id),
        {}, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
  </fieldset>
  <fieldset>
    <%= f.label :avito_status, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :avito_status,
        AvitoOrderStatusMapping::TRANSITIONS.map { |transition|
          [t("avito_order_status_mappings.transitions.#{transition}"), transition]
        },
        { include_blank: true },
        class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm" %>
    <p class="text-xs text-gray-500 mt-1"><%= t("avito_order_status_mappings.form.avito_status_hint") %></p>
  </fieldset>
  <div class="flex justify-end">
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
