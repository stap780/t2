<% avito = local_assigns[:avito] || @avito %>
<%= turbo_frame_tag dom_id(mapping), class: "grid grid-cols-[2fr_1fr_120px] gap-4 p-4 border-t hover:bg-gray-50 items-center" do %>
  <div>
    <% if mapping.order_status %>
      <span class="px-2 py-1 text-xs font-medium rounded-full <%= mapping.order_status.color %>">
        <%= mapping.order_status.title %>
      </span>
    <% end %>
  </div>
  <div class="text-sm">
    <span class="font-mono"><%= mapping.avito_status %></span>
    <span class="text-gray-500">— <%= t("avito_order_status_mappings.transitions.#{mapping.avito_status}") %></span>
  </div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_avito_avito_order_status_mapping_path(avito, mapping), data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
    <%= link_to_delete avito_avito_order_status_mapping_path(avito, mapping), data: { turbo_method: :delete, turbo_confirm: t("actions.delete") } %>
  </div>
<% end %>
