<% content_for :title, "Акт ##{@act.id}" %>
<% incases = @act.items.includes(:incase).map(&:incase).uniq.compact %>
<% sort_incases = incases.sort_by(&:date) %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <%= link_to t('.back_to_list'), acts_path, class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300" %>
    <h1 class="text-2xl font-semibold text-gray-900"><%= t('.heading') %> №<%= @act.number %></h1>
    <div class="flex space-x-2 items-center">
      <%= link_to "PDF", print_act_path(@act, format: :pdf), class: "px-3 py-1 rounded-md border border-blue-300 hover:bg-violet-200", target: '_blank' %>

      <!-- Print Etiketkas Dropdown for Act -->
      <div class="relative inline-block" data-controller="dropdown">
        <button type="button" data-action="click->dropdown#toggle"
         class="inline-flex items-center px-3 py-2 bg-green-600 text-white rounded-md hover:bg-green-700">
          <!-- Simple barcode icon -->
          <%= barcode_icon %>
          <!-- Dropdown arrow -->
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="hidden absolute right-0 mt-2 w-56 bg-white rounded-md shadow-lg z-10" data-dropdown-target="menu">
          <div class="py-1">
            <!-- All items in act -->
            <%= link_to t('.print_etiketkas_all'),
                        print_etiketkas_act_path(@act, format: :pdf),
                        class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100",
                        target: "_blank",
                        data: { turbo: false } %>
            <!-- Selected items in act -->
            <button type="submit"
                    class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100"
                    form="act_items_print_form"
                    formaction="<%= print_selected_etiketkas_act_path(@act, format: :pdf) %>"
                    formmethod="post">
              <span><%= t('.print_etiketkas_selected') %></span>
            </button>
          </div>
        </div>
      </div>
      <%= form_with url: print_selected_etiketkas_act_path(@act, format: :pdf, status: 'Да'), method: :post, target: '_blank', data: { turbo: false } do |f| %>
        <button type="submit" class="px-2 py-1 rounded-md border border-green-300 hover:bg-green-100 inline-flex items-center gap-1 cursor-pointer">
          <%= barcode_icon %>
          <span><%= t('acts.show.print_etiketkas_yes') %></span>
        </button>
      <% end %>
      <%= form_with url: print_selected_etiketkas_act_path(@act, format: :pdf, status: 'В работе'), method: :post, target: '_blank', data: { turbo: false } do |f| %>
        <button type="submit" class="px-2 py-1 rounded-md border border-green-300 hover:bg-green-100 inline-flex items-center gap-1 cursor-pointer">
          <%= barcode_icon %>
          <span><%= t('acts.show.print_etiketkas_in_work') %></span>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Hidden form for printing selected items' etiketas -->
  <%= form_with url: print_selected_etiketkas_act_path(@act, format: :pdf),method: :post, id: :act_items_print_form,local: true do |f| %>
  <% end %>

  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Информация о компании (принимающая сторона) -->
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2"><%= t('.receiving_party') %></h2>
        <p class="text-gray-700 font-medium"><%=link_to @act.company&.title, edit_company_path(@act.company), class: "text-blue-600 hover:text-blue-800 cursor-pointer", target: '_blank', data: { turbo: false } %> <%= @act.company&.ur_address %></p>
      </div>

      <!-- Информация о страховой компании (передающая сторона) -->
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2"><%= t('.transferring_party') %></h2>
        <%= form_with model: @act do |f| %>
          <%= f.collection_select :strah_id_eq, Company.strah, :id, :short_title, { include_blank: false }, 
              onchange: 'this.form.requestSubmit();', 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-violet-500 focus:border-violet-500 h-8", 
              style: "max-width: 250px;" %>
        <% end %>
      </div>
    </div>

    <div class="mt-3 pt-3 border-t border-gray-200">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <span class="text-sm text-gray-500"><%= t('.act_date') %>:</span>
          <%= form_with model: @act do |f| %>
            <%= f.date_field :date, 
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-violet-500 focus:border-violet-500 h-8", 
              style: "max-width: 250px;",
              onchange: 'this.form.requestSubmit();' %>
          <% end %>
        </div>
        <div>
          <span class="text-sm text-gray-500"><%= t('.status') %>:</span>
          <%= form_with model: @act do |f| %>
            <%= f.select :status, options_for_select(Act.statuses.keys.map { |k| [t("enums.act.status.#{k}"), k] }, @act.status), { include_blank: false }, 
                onchange: 'this.form.requestSubmit();', 
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-violet-500 focus:border-violet-500 h-8", 
                style: "max-width: 250px;" %>
          <% end %>
        </div>
        <div>
          <% if @act.driver.present? %>
            <span class="text-sm text-gray-500"><%= t('.driver') %>:</span>
            <div class="flex items-center gap-2">
              <p class="text-gray-800 font-medium"><%= @act.driver.email_address %></p>
              <%= button_to send_to_driver_act_path(@act), method: :post,
                  class: "mt-1 px-3 py-1 text-sm rounded-md cursor-pointer",
                  data: { turbo: false }, title: t('.send_to_driver') do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
              <% end %>
            </div>
          <% end %>
        </div>
        <div>
          <span class="text-sm text-gray-500">Позиции</span>
          <%= form_with url: bulk_update_item_status_act_path(@act), method: :post, data: { turbo_stream: true, turbo_preserve_scroll: "true" } do |f| %>
            <% sort_incases.each do |incase| %>
              <% @act.items.where(incase: incase).order(:title).each do |item| %>
                <%= hidden_field_tag 'item_ids[]', item.id %>
              <% end %>
            <% end %>
            <%= f.select :item_status_id, options_for_select(ItemStatus.all.map { |s| [s.title, s.id] }), { include_blank: false, prompt: t('activerecord.attributes.item.item_status_id') }, onchange: 'this.form.requestSubmit();', class: "w-full px-2 py-1 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-violet-500 focus:border-violet-500 text-sm h-8", style: "max-width: 250px;" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Позиции акта, сгруппированные по заявкам -->
  <div class="bg-white rounded-lg shadow-md p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= t('.items') %></h2>
    <% sort_incases.each do |incase| %>
      <%= turbo_stream_from dom_id(incase, 'items') %>
      <% act_items_from_incase = @act.items.where(incase: incase).order(:title) %>
      <div class="incase-wrapper mb-6 border border-gray-200 rounded-lg overflow-hidden">
        <!-- Заголовок заявки -->
        <div class="bg-gray-100 px-4 py-3 border-b border-gray-200">
          <div class="grid grid-cols-1 md:grid-cols-[1fr_50px_200px_200px] gap-4">
            <div>
              <span class="text-sm font-semibold text-gray-900">
                <%= incase.stoanumber.present? ? "Номер З/Н #{incase.stoanumber}" : "Заявка ##{incase.id}" %>
              </span>
              <span class="text-xs text-gray-500">ТС:</span>
              <span class="text-sm font-semibold text-gray-900">
                <%= incase.modelauto || 'Не указано' %> (<%= incase.carnumber || 'Не указано' %>)
              </span>
              <span class="text-xs text-gray-500">№ ВД:</span>
              <span class="text-sm font-semibold text-gray-900">
                <%=link_to incase.unumber, edit_incase_path(incase), class: "text-blue-600 hover:text-blue-800 cursor-pointer", target: '_blank', data: { turbo: false } %> от <%= incase.date&.strftime('%d.%m.%Y') %>
              </span>
            </div>
            <div>
              <%= form_with url: print_selected_etiketkas_act_path(@act, format: :pdf), method: :post, target: '_blank', data: { turbo: false } do |f| %>
                <% act_items_from_incase.each do |item| %>
                  <%= hidden_field_tag 'item_ids[]', item.id %>
                <% end %>
                <button type="submit" target="_blank" class="p-2 rounded-md bg-gray-50 hover:bg-gray-100 flex items-center justify-center h-8 cursor-pointer" title="<%= t('print_barcode') %>">
                  <%= barcode_icon %>
                </button>
              <% end %>
            </div>
            <div>
              <%= form_with url: bulk_update_status_incase_items_path(incase), method: :post, data: { turbo_stream: true, turbo_preserve_scroll: "true" } do |f| %>
                <% act_items_from_incase.each do |item| %>
                  <%= hidden_field_tag 'item_ids[]', item.id %>
                <% end %>
                <%= f.select :item_status_id, options_for_select(ItemStatus.all.map { |s| [s.title, s.id] }), { include_blank: false, prompt: t('activerecord.attributes.item.item_status_id') }, onchange: 'this.form.requestSubmit();', class: "w-full px-2 py-1 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-violet-500 focus:border-violet-500 text-sm", style: "max-width: 250px;" %>
              <% end %>
            </div>
            <div>Состояние</div>
          </div>
        </div>

        <!-- Позиции этой заявки -->
        <div class="divide-y divide-gray-200">
          <% act_items_from_incase.each do |item| %>
            <%= render "items/act_show", item: item, incase: incase %>
          <% end %>
        </div>

      </div>
      <% end %>
    </div>
  </div>

</div>

