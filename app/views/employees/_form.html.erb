<%= form_with model: employee, class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: employee %>

  <fieldset>
    <%= f.label :full_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :full_name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" %>
  </fieldset>

  <fieldset>
    <%= f.label :department_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :department_id, Department.order(:name), :id, :name, { include_blank: t(".department_blank") }, { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" } %>
  </fieldset>

  <fieldset>
    <%= f.label :manager_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% managers = employee.persisted? ? Employee.where.not(id: employee.id).order(:position) : Employee.order(:position) %>
    <%= f.collection_select :manager_id, managers, :id, :full_name, { include_blank: t(".manager_blank") }, { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" } %>
  </fieldset>

  <fieldset>
    <%= f.label :user_id, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :user_id, User.order(:email_address), :id, :email_address, { include_blank: t(".user_blank") }, { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" } %>
  </fieldset>

  <div class="flex justify-end space-x-3">
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
