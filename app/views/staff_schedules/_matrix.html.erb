<div class="max-w-[100vw] xl:max-w-7xl px-1 sm:px-0">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
    <div>
      <h2 class="text-xl font-semibold text-gray-900"><%= t("staff_schedules.matrix.heading") %></h2>
    </div>
    <div class="flex items-center gap-2 flex-wrap shrink-0">
      <%= link_to staff_schedules_path_for_month(staff_schedule_prev_month(@month)),
          class: "inline-flex items-center px-2 py-1 text-sm border border-gray-300 rounded-md bg-white hover:bg-gray-50" do %>
        ←
      <% end %>
      <span class="text-sm font-medium text-gray-900 min-w-[10rem] text-center">
        <%= l(@month, format: :month_year) %>
      </span>
      <%= link_to staff_schedules_path_for_month(staff_schedule_next_month(@month)),
          class: "inline-flex items-center px-2 py-1 text-sm border border-gray-300 rounded-md bg-white hover:bg-gray-50" do %>
        →
      <% end %>
      <%= link_to t("staff_schedules.index.today"), staff_schedules_path_for_month(Date.current.beginning_of_month),
          class: "text-xs text-violet-600 hover:text-violet-800" %>
      <%= link_to export_staff_schedules_path(month: staff_schedule_month_param(@month)), class: "inline-flex items-center px-3 py-1 bg-green-600 text-white rounded-md hover:bg-green-700 cursor-pointer", data: { turbo: false } do %>
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Excel
      <% end %>
    </div>
  </div>

  <% if @employees.empty? %>
    <p class="text-sm text-gray-500 py-8"><%= t("staff_schedules.matrix.empty_employees") %></p>
  <% else %>
    <div class="overflow-x-auto border border-gray-200 rounded-lg bg-white shadow-sm">
      <table class="min-w-max w-full text-xs border-collapse">
        <thead>
          <tr class="bg-gray-50 text-gray-700">
            <th class="sticky left-0 min-w-[10rem] max-w-[14rem] px-2 py-2 text-left font-medium border-b border-r border-gray-200 bg-gray-50 shadow-[2px_0_4px_-2px_rgba(0,0,0,0.06)]">
              <%= t("staff_schedules.matrix.employee_col") %>
            </th>
            <% @days.each do |day| %>
              <th class="px-0.5 py-1.5 text-center font-normal border-b border-gray-200 w-8 min-w-[2rem] <%= 'bg-slate-100/80' if day.saturday? || day.sunday? %>"
                  title="<%= l(day, format: :long) %>">
                <span class="block text-[0.65rem] text-gray-500 leading-none"><%= l(day, format: "%a") %></span>
                <span class="block font-medium text-gray-900"><%= day.day %></span>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="text-gray-900">
          <% @employees.each do |employee| %>
            <tr class="border-b border-gray-100 hover:bg-gray-50/80">
              <td class="sticky left-0 px-2 py-1.5 align-middle border-r border-gray-200 bg-white shadow-[2px_0_4px_-2px_rgba(0,0,0,0.06)]">
                <div class="min-w-0">
                  <%= link_to employee.full_name,
                      schedule_employee_path(employee, year: @month.year),
                      class: "text-violet-700 hover:text-violet-900 font-medium truncate block",
                      data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
                  <% if employee.department %>
                    <div class="text-[0.65rem] text-gray-500 truncate"><%= employee.department.name %></div>
                  <% end %>
                </div>
              </td>
              <% row = @matrix[employee.id] || {} %>
              <% @days.each do |day| %>
                <% sd = row[day] %>
                <%= render "staff_schedules/matrix_day_cell",
                    employee: employee,
                    day: day,
                    schedule_day: sd %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @shift_codes.any? %>
      <div class="mt-6 p-4 bg-white border border-gray-200 rounded-lg">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2"><%= t("staff_schedules.matrix.legend") %></p>
        <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-gray-700">
          <% @shift_codes.each do |sc| %>
            <li class="inline-flex items-center gap-2">
              <% if sc.color.present? %>
                <span class="inline-block w-4 h-4 rounded border border-gray-200 shrink-0" style="background-color: <%= sc.color %>"></span>
              <% else %>
                <span class="inline-block w-4 h-4 rounded border border-dashed border-gray-300 bg-gray-50 shrink-0"></span>
              <% end %>
              <span><span class="font-mono text-xs text-gray-600"><%# sc.code %></span><%= sc.label %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  <% end %>
</div>
