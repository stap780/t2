<%= turbo_frame_tag dom_id(department), class: "grid grid-cols-[50px_1fr_200px] gap-4 p-4 border-t hover:bg-gray-50" do %>
  <div><%= department.id %></div>
  <div>
    <%= link_to department.name, edit_department_path(department), class: "text-blue-600 hover:text-blue-800 font-medium", data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
  </div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_department_path(department), data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
    <%= link_to_delete department_path(department), data: { turbo_method: :delete, turbo_confirm: t("actions.delete") } %>
  </div>
<% end %>
