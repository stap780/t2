<%= form_with model: department, class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: department %>

  <fieldset>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" %>
  </fieldset>

  <div class="flex justify-end space-x-3">
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
