<div class="space-y-4">
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :sku, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :sku, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
    <div>
      <%= f.label :barcode, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :barcode, class: "w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-400 cursor-not-allowed", disabled: true %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div>
      <%= f.label :quantity, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :quantity, step: 1, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-400 cursor-not-allowed", disabled: true %>
    </div>
    <div>
      <%= f.label :cost_price, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :cost_price, step: 1, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
    <div>
      <%= f.label :sprice, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :sprice, step: 1, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
    <div>
      <%= f.label :price, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price, step: 1, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    </div>
  </div>
</div>