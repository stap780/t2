<!-- Bulk Delete Buttons -->
<div class="relative inline-block" data-controller="dropdown">
  <button type="button" class="inline-flex items-center px-3 py-1 bg-red-600 text-white rounded-md hover:bg-red-700 cursor-pointer h-8"
          data-action="click->dropdown#toggle" title="Удалить">
    <%= delete_icon %> <%= dropdown_icon %>
  </button>
  <div class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg z-1" data-dropdown-target="menu">
    <div class="py-1">
      <%= f.button 'Выбранное', type: :submit, 
          class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", 
          formaction: polymorphic_path(object, action: 'bulk_delete', delete_type: :selected), 
          data: { 'turbo-confirm': 'Are you sure?'} %>
      <%= f.button 'Отфильтрованное', type: :submit, 
          class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100", 
          formaction: polymorphic_path(object, action: 'bulk_delete', delete_type: :filtered), 
          data: { 'turbo-confirm': 'Are you sure?'} %>
    </div>
  </div>
</div>