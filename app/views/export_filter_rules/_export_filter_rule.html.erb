<% key = turbo_id_for(export_filter_rule).to_s %>
<%= turbo_frame_tag "export_filter_rule_#{key}", class: "w-full block" do %>
  <%= fields_for "export[export_filter_rules_attributes][#{key}]", export_filter_rule do |ff| %>
    <div class="grid gap-2 p-1 border-t hover:bg-gray-50"
      style="grid-template-columns: minmax(140px, 1fr) 110px minmax(140px, 1fr) 60px;">
      <%= ff.hidden_field :id if export_filter_rule.persisted? %>
      <%= ff.hidden_field :rule_key %>
      <%= ff.hidden_field :property_id %>

      <%= select_tag "export[export_filter_rules_attributes][#{key}][field_selector]",
        options_for_select(
          ExportFilterRule.field_options,
          export_filter_rule.field_selector_value
        ),
        include_blank: t("exports.form.select_field"),
        class: "w-full min-w-0 px-2 py-1 border rounded-md",
        data: {
          controller: "slimselect",
          turbo_frame: "export_filter_rule_#{key}",
          nested_url: characteristics_export_export_filter_rule_path(export, key)
        } %>

      <%= ff.select :rule_condition,
        options_for_select(
          [
            [t("exports.form.predicate_eq"), "eq"],
            [t("exports.form.predicate_not_eq"), "not_eq"]
          ],
          export_filter_rule.rule_condition
        ),
        {},
        class: "w-full min-w-0 px-2 py-1 border rounded-md text-sm" %>

      <% if export_filter_rule.integration_rule? %>
        <%= ff.select :rule_value,
          options_for_select(
            [
              [t("exports.form.binding_value_yes"), "yes"],
              [t("exports.form.binding_value_no"), "no"]
            ],
            export_filter_rule.rule_value
          ),
          {},
          class: "w-full min-w-0 px-2 py-1 border rounded-md text-sm" %>
      <% else %>
        <%= turbo_frame_tag "export_filter_rule_#{key}_characteristic" do %>
          <%= ff.collection_select :characteristic_id,
            (export_filter_rule.property&.characteristics&.order(:title) || Characteristic.none),
            :id,
            :title,
            { prompt: t("features.select_characteristic"), selected: export_filter_rule.characteristic_id },
            {
              class: "w-full min-w-0 px-2 py-1 border rounded-md",
              id: "export_filter_rule_#{key}_characteristic_id",
              data: {
                controller: "slimselect",
                search_url: search_characteristics_path,
                property_id: export_filter_rule.property_id
              }
            } %>
        <% end %>
      <% end %>

      <%= link_to_delete export_export_filter_rule_path(export, key),
        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </div>
  <% end %>
<% end %>
