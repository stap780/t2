<%= turbo_frame_tag dom_id(shift_code), class: "grid grid-cols-[50px_1fr_80px_100px_56px_56px_200px] gap-4 p-4 border-t hover:bg-gray-50" do %>
  <div><%= shift_code.id %></div>
  <div>
    <%= link_to shift_code.label, edit_shift_code_path(shift_code), class: "text-blue-600 hover:text-blue-800 font-medium", data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
  </div>
  <div class="font-mono text-sm text-gray-700"><%= shift_code.code %></div>
  <div>
    <% if shift_code.color.present? %>
      <span class="inline-block w-6 h-6 rounded-full border border-gray-200" style="background-color: <%= shift_code.color %>"></span>
    <% end %>
  </div>
  <div class="text-center text-sm"><%= shift_code.vacation ? "✓" : "—" %></div>
  <div class="text-center text-sm"><%= shift_code.day_off ? "✓" : "—" %></div>
  <div class="flex justify-end space-x-2">
    <%= link_to_edit edit_shift_code_path(shift_code), data: { turbo_frame: "offcanvas", turbo_prefetch: false } %>
    <%= link_to_delete shift_code_path(shift_code), data: { turbo_method: :delete, turbo_confirm: t("actions.delete") } %>
  </div>
<% end %>
