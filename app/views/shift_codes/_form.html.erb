<%= form_with model: shift_code, class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: shift_code %>

  <fieldset>
    <%= f.label :label, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :label, class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-violet-500 focus:border-violet-500" %>
  </fieldset>

  <fieldset>
    <%= f.label :color, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% code_color = shift_code.color.to_s.strip
       code_color = "#22c55e" if code_color.blank? || !code_color.match?(/\A#(?:[0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})\z/) %>
    <%= f.text_field :color, type: "color", value: code_color, class: "w-full h-10 border border-gray-300 rounded-md" %>
  </fieldset>

  <fieldset class="flex flex-wrap items-center gap-6">
    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
      <%= f.check_box :vacation, class: "rounded border-gray-300 text-violet-600" %>
      <%= ShiftCode.human_attribute_name(:vacation) %>
    </label>
    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
      <%= f.check_box :day_off, class: "rounded border-gray-300 text-violet-600" %>
      <%= ShiftCode.human_attribute_name(:day_off) %>
    </label>
  </fieldset>

  <div class="flex justify-end space-x-3">
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
