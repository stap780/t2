<%= form_with model: export, local: true, class: "space-y-8", data: { controller: "export-form" } do |form| %>
  <%= render "shared/errors", object: export %>

  <div class="grid grid-cols-1 gap-8">
    <div class="flex flex-wrap gap-4">
      <!-- Export Name -->
      <div class="flex flex-col w-full sm:w-auto flex-1 min-w-[210px]">
        <%= form.label( :name, t("activerecord.attributes.export.name"),
          class: "block text-sm font-semibold text-gray-800 mb-2"
        ) %>
        <%= form.text_field( :name, placeholder: t("exports.form.name_placeholder"),
          class: "block w-full px-3 py-2 border-1 border-gray-200 rounded-lg shadow-sm focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition duration-200 ease-in-out text-gray-900 placeholder-gray-400"
        ) %>
        <!-- Test Mode Toggle -->
        <div class="flex flex-col justify-center w-full sm:w-auto flex-1 min-w-[210px]">
          <div class="flex items-center">
            <%= form.check_box(
              :test,
              class: "h-4 w-4 text-violet-600 focus:ring-violet-500 border-gray-300 rounded"
            ) %>
            <div class="ml-3">
              <%= form.label(
                :test,
                t("exports.form.test_mode"),
                class: "block text-sm font-semibold text-gray-800"
              ) %>
              <p class="text-xs text-gray-600">
                <%= t("exports.form.test_limit_html", count: Export::TEST_LIMIT).html_safe %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Schedule: interval or daily time -->
      <div class="flex flex-col w-full sm:w-auto flex-1 min-w-[210px] max-w-[360px]">
        <%= form.label(
          :interval_hours,
          t("exports.form.interval_label"),
          class: "block text-sm font-semibold text-gray-800 mb-2"
        ) %>
        <p class="text-xs text-gray-600 mb-2"><%= t("exports.form.schedule_hint") %></p>
        <%= form.select(
          :interval_hours,
          options_for_select(
            [
              [t("exports.form.not_set"), nil], 
              [t("exports.form.every_n_hours", count: 1), 1], 
              [t("exports.form.every_n_hours", count: 2), 2], 
              [t("exports.form.every_n_hours", count: 3), 3],
              [t("exports.form.every_n_hours", count: 4), 4],
              [t("exports.form.every_n_hours", count: 5), 5],
              [t("exports.form.every_n_hours", count: 6), 6]
            ],
            selected: form.object.interval_hours
          ),
          {},
          class: "block w-full px-3 py-2 border-1 border-gray-200 rounded-lg shadow-sm focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition duration-200 ease-in-out text-gray-900"
        ) %>
      </div>
      <!-- Export Time (15-minute intervals) - for daily run -->
      <div class="flex flex-col w-full sm:w-auto flex-1 min-w-[210px] max-w-[290px]">
        <%= form.label(
          :time,
          t("exports.form.scheduled_time"),
          class: "block text-sm font-semibold text-gray-800 mb-2"
        ) %>
        <p class="text-xs text-gray-600 mb-2"><%= t("exports.form.time_hint") %></p>
        <% time_options = (0..23).flat_map { |h| [0, 15, 30, 45].map { |m| format("%02d:%02d", h, m) } } %>
        <%= form.select(
          :time,
          options_for_select(time_options, selected: form.object.time),
          { include_blank: t("exports.form.not_set") },
          class: "block w-full px-3 py-2 border-1 border-gray-200 rounded-lg shadow-sm focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition duration-200 ease-in-out text-gray-900"
        ) %>
      </div>
    </div>

    <%= render "export_filters", export: export if export.persisted?  %>

    <!-- Data Source Info -->
    <% unless export.has_data_source? %>
      <div class="space-y-3 p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <h3 class="text-sm font-semibold text-blue-800">
          <%= t("exports.form.data_source") %>
        </h3>
        <div class="text-sm text-orange-700">
          <p><%= t("exports.form.no_products") %></p>
        </div>
      </div>
    <% end %>

    <!-- Export Format -->
    <div class="space-y-3 mt-2 mb-2">
      <%= form.label(
        :format,
        t("exports.form.export_format"),
        class: "block text-sm font-semibold text-gray-800"
      ) %>
      <p class="text-xs text-gray-600 mt-2 mb-2"><%= t("exports.form.export_format_hint") %></p>
      <div class="flex flex-wrap gap-4">
        <% %w[csv xlsx xml].each do |format_option| %>
          <label class="flex items-center cursor-pointer">
            <%= form.radio_button(
              :format,
              format_option,
              class: "w-4 h-4 text-violet-600 border-gray-300 focus:ring-violet-500 focus:ring-2",
              data: { action: "change->export-form#formatChanged" }
            ) %>
            <span class="ml-2 text-sm font-medium text-gray-900">
              <%= format_option.upcase %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <%= render "export_columns", export: export if export.persisted? %>

    <% if !export.persisted? %>
      <div
        class="space-y-2 mt-2 mb-2 p-4 bg-gray-50 border border-gray-200 rounded-lg"
        id="field-selection"
        data-export-form-target="fieldSelection"
        style="display: none;">
        <p class="text-xs text-gray-600"><%= t("exports.form.columns_after_save") %></p>
      </div>
    <% end %>

    <!-- Template Section (XML only) -->
    <div
      id="template-section"
      data-export-form-target="templateSection"
      style="display: none;" >
      <div class="border-1 border-gray-200 rounded-xl overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 font-semibold text-gray-800">
          <span class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
              ></path>
            </svg>
            <span><%= t("exports.form.xml_required") %></span>
          </span>
        </div>

        <div class="p-4 bg-gray-50 border-t border-gray-200 space-y-4">
          <div class="p-4 bg-blue-50 border-l-4 border-blue-400 rounded-r-lg">
            <p class="text-sm text-blue-800">
              <%= t("exports.form.xml_hint") %>
            </p>
            <p class="mt-2 text-xs font-semibold text-blue-700">
              <%= link_to(
                "Пример Avito",
                xml_avito_example_exports_path,
                target: "_blank",
                data: { turbo: false }
              ) %>
            </p>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-1 gap-2">
            <!-- Layout template -->
            <div>
              <%= form.label(
                :layout_template,
                "Layout-шаблон (каркас файла)",
                class: "block text-sm font-semibold text-gray-800 mb-2"
              ) %>
              <p class="text-xs text-gray-600 mb-2">
                Здесь задаётся общий XML, например Avito или YML: заголовок, корневые теги, &lt;shop&gt;, &lt;offers&gt; и т.п.
                Внутрь нужного места вставьте
                <code class="bg-gray-100 px-1 py-0.5 rounded">{"{{ items_xml }}"}</code> отвечающий за вывод списка товаров.
              </p>
              <div
                data-controller="codemirror"
                data-codemirror-doc-value="<%= form.object.layout_template %>"
              >
                <div data-codemirror-target="editor">
                  <%= form.hidden_field(
                    :layout_template,
                    data: { codemirror_target: "input" }
                  ) %>
                </div>
              </div>
            </div>

            <!-- Item template -->
            <div>
              <%= form.label( :item_template, "XML item (один товар)",
                class: "block text-sm font-semibold text-gray-800 mb-2" ) %>
              <p class="text-xs text-gray-600 mb-2">
                Item-шаблон одного товара. Внутри доступен объект
                <code class="bg-gray-100 px-1 py-0.5 rounded">product</code>
                и его поля (id, title, variants, features, images и т.д.).
              </p>
              <div data-controller="codemirror"
                data-codemirror-doc-value="<%= form.object.item_template %>" >
                <div data-codemirror-target="editor">
                  <%= form.hidden_field(
                    :item_template,
                    data: { codemirror_target: "input" }
                  ) %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 p-4 bg-white rounded-lg border border-gray-200">
        <p class="text-sm font-semibold text-gray-700 mb-2">
          🔧 <%= t("exports.form.available_objects") %>:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs text-gray-600">
          <div>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product</code>
              - <%= t("exports.form.obj_product") %>
            </p>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product.variants</code>
              - массив вариантов товара
            </p>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product.features</code>
              - массив свойств [{property, characteristic}]
            </p>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product.bindings</code>
              - привязки товара [{bindable_type, bindable_id, value}]
            </p>
          </div>
          <div>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product.images</code>
              - массив URL изображений
            </p>
            <p class="mt-1">
              <code class="bg-gray-100 px-2 py-1 rounded">product.images_with_ext</code>
              - массив URL изображений с расширением (.jpg, .png)
            </p>
          </div>
        </div>

        <%# List all fields available on `product` from Product model %>
        <% template_fields = Export.available_product_fields_for_template %>
        <div class="mt-4">
          <p class="text-sm font-semibold text-gray-700 mb-2">
            📋 <%= t("exports.form.product_fields") %>
            (<%= t("exports.form.use_as_html") %>):
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2 text-xs text-gray-700 max-h-64 overflow-auto p-2 bg-gray-50 border border-gray-200 rounded">
            <%# Product fields %>
            <% template_fields[:product_fields].each do |field| %>
              <div class="flex items-center">
                <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                  {{ product.<%= field %> }}
                </code>
              </div>
            <% end %>

            <%# Variant fields %>
            <% template_fields[:variant_fields].each do |field| %>
              <div class="flex items-center">
                <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                  {{ <%= field %> }}
                </code>
              </div>
            <% end %>

            <%# Features - итерация по всем свойствам %>
            <div class="flex items-center">
              <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                {% for f in product.features %}</br> {{ f.property }}: {{ f.characteristic }}</br>{% endfor %}
              </code>
            </div>

            <%# Bindings - product (Avito) и variant (MoySklad, InSales) %>
            <div class="flex items-center col-span-full">
              <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                {% for b in product.bindings %}</br> {{ b.bindable_type }} #{{ b.bindable_id }}: {{ b.value }}</br>{% endfor %}
              </code>
            </div>
            <div class="flex items-center col-span-full">
              <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                {% assign v = product.variants.first %}{% for b in v.bindings %}</br> {{ b.bindable_type }}: {{ b.value }}</br>{% endfor %}
              </code>
            </div>

            <%# Image iteration %>
            <div class="flex items-center">
              <code class="bg-white border border-gray-200 px-2 py-1 rounded w-full truncate">
                {% for image in product.images_with_ext %}</br> {{ image }}</br>{% endfor %}
              </code>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Action Buttons -->
  <div class="flex items-center justify-between pt-6 border-t border-gray-200">
    <div class="text-sm text-gray-500">
      <p><%= t("exports.form.footer_hint") %></p>
    </div>
    <div class="flex items-center space-x-4">
      <%= link_to t("actions.cancel"), exports_path,
        class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300",
        data: { turbo: false } %>
      <%= form.submit t("actions.save"),
        class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700 cursor-pointer"
      %>
    </div>
  </div>

<% end %>
