<% content_for :title, "Отчёты по убыткам" %>

<div class="mb-6">
  <h1 class="text-xl font-semibold text-gray-900">Отчёты по убыткам</h1>
</div>

<%= form_with url: reports_incases_path, method: :get, html: { class: "flex flex-wrap items-end gap-4 mb-6 p-4 bg-white rounded-lg shadow", data: { turbo_frame: "incase_reports" } } do |f| %>
  <div>
    <%= label_tag :date_from, "Дата от", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= date_field_tag :date_from, @date_from, class: "h-8 px-3 py-2 border border-gray-300 rounded-md focus:ring-violet-500 focus:border-violet-500" %>
  </div>
  <div>
    <%= label_tag :date_to, "Дата до", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= date_field_tag :date_to, @date_to, class: "h-8 px-3 py-2 border border-gray-300 rounded-md focus:ring-violet-500 focus:border-violet-500" %>
  </div>
  <%= submit_tag "Применить", class: "h-8 px-2 bg-violet-600 text-white rounded-md hover:bg-violet-700 cursor-pointer" %>
<% end %>

<%= turbo_stream_from "incases" %>

<%= turbo_frame_tag "incase_reports" do %>
  <% if @totals&.dig(:count).to_i > 0 %>
    <% priced_pct = @totals[:count].positive? ? (@totals[:priced_count].to_f / @totals[:count] * 100).round(1) : 0 %>

    <div class="grid grid-cols-2 md:grid-cols-6 gap-4 mb-6">
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">Сумма</div>
        <div class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@totals[:totalsum].round(2), delimiter: " ") %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">В страховую</div>
        <div class="text-lg font-semibold text-gray-900"><%= number_with_delimiter((@totals[:strah_amount] || 0).round(2), delimiter: " ") %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">Сумма деталей</div>
        <div class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@totals[:items_sum].round(2), delimiter: " ") %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">Сумма продажных цен</div>
        <div class="text-lg font-semibold text-gray-900"><%= number_with_delimiter(@totals[:items_sale_sum].round(2), delimiter: " ") %></div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">Проценены</div>
        <div class="text-lg font-semibold text-gray-900"><%= priced_pct %>%</div>
      </div>
      <div class="bg-white rounded-lg shadow p-4">
        <div class="text-sm font-medium text-gray-500">НЕ ПРОЦ.</div>
        <div class="text-lg font-semibold text-gray-900"><%= @totals[:unpriced_count] %></div>
      </div>
    </div>

    <div id="report_chart" class="bg-white rounded-lg shadow p-4 mb-6"
         data-controller="chartjs"
         data-chartjs-type-value="bar"
         data-chartjs-data-value='<%= @chart_data.to_json %>'>
      <div class="mb-4">
        <h2 class="text-lg font-medium text-gray-900">График по месяцам</h2>
      </div>
      <div class="h-80">
        <canvas data-chartjs-target="canvas"></canvas>
      </div>
    </div>

    <%= turbo_frame_tag "incase_reports_table" do %>
    <div class="flex flex-wrap items-end gap-2 mb-4 p-4 bg-white rounded-lg shadow">
    <%= search_form_for @search, url: reports_incases_path, method: :get, html: { class: "flex flex-wrap items-end gap-2", data: { turbo_frame: "incase_reports_table" } } do |f| %>
      <%= hidden_field_tag :date_from, @date_from %>
      <%= hidden_field_tag :date_to, @date_to %>
      <div>
        <%= f.label :unumber_cont, "Номер убытка", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.search_field :unumber_cont, class: "h-8 px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <%= f.label :stoanumber_cont, "З.Н.", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.search_field :stoanumber_cont, class: "h-8 px-3 py-2 border border-gray-300 rounded-md" %>
      </div>
      <div>
        <%= f.label :company_id_eq, "СТО", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :company_id_eq, Company.standart.limit(20), :id, :short_title, { include_blank: true }, { class: "h-8 px-3 py-2 border border-gray-300 rounded-md" } %>
      </div>
      <%= f.submit "Поиск", class: "h-8 px-2 bg-violet-600 text-white rounded-md hover:bg-violet-700 cursor-pointer" %>
      <%= link_to reports_incases_path( date_from: @date_from, date_to: @date_to, search_cancel: true ), class: "h-8 p-2 bg-gray-200 text-gray-700 rounded-md hover:bg-gray-300", data: { turbo: false } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      <% end %>
    <% end %>
    <%= form_with url: download_incases_path, method: :post, local: false, class: "inline" do |ef| %>
      <%= hidden_field_tag :date_from, @date_from %>
      <%= hidden_field_tag :date_to, @date_to %>
      <%= hidden_field_tag :download_type, 'reports' %>
      <% (params[:q] || {}).each do |key, value| %>
        <% next if value.blank? %>
        <% if value.is_a?(Array) %>
          <% value.reject(&:blank?).each do |v| %>
            <%= hidden_field_tag "q[#{key}][]", v %>
          <% end %>
        <% else %>
          <%= hidden_field_tag "q[#{key}]", value %>
        <% end %>
      <% end %>
      <div class="relative inline-block" data-controller="dropdown">
        <button type="button" class="inline-flex items-center px-3 py-1 bg-green-600 text-white rounded-md hover:bg-green-700 cursor-pointer" data-action="click->dropdown#toggle">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Экспорт C
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="hidden absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg z-10" data-dropdown-target="menu">
          <div class="py-1">
            <%= ef.button 'Общий', type: :submit, name: :download_kind, value: 'mono',
                class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer" %>
            <%= ef.button 'Детально', type: :submit, name: :download_kind, value: '',
                class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 cursor-pointer" %>
          </div>
        </div>
      </div>
    <% end %>
    </div>
      <div class="bg-white rounded-lg shadow">
        <div class="overflow-x-auto">
          <div class="min-w-[960px]">
            <div class="grid grid-cols-[minmax(140px,1fr)_minmax(100px,1fr)_minmax(90px,1fr)_minmax(100px,1fr)_minmax(95px,1fr)_minmax(95px,1fr)_minmax(110px,1fr)_minmax(80px,1fr)_minmax(85px,1fr)_minmax(70px,1fr)_40px] gap-x-2 px-4 py-2 bg-gray-50 text-xs font-medium text-gray-500 uppercase border-b border-gray-200">
              <div class="text-left whitespace-nowrap">Номер убытка</div>
              <div class="text-left whitespace-nowrap">З.Н.</div>
              <div class="text-left whitespace-nowrap">Дата акта</div>
              <%= header_with_info("Сумма", tooltip: "Сумма убытка по акту (totalsum)") %>
              <%= header_with_info("В страховую", tooltip: "Сумма, которую платим в страховую (totalsum × % СК)") %>
              <%= header_with_info("Сумма Д", tooltip: "Сумма деталей: сумма (кол-во × цена позиции) по всем позициям") %>
              <%= header_with_info("Пр. цены", tooltip: "Сумма продажных цен: сумма (кол-во × цена варианта) по всем позициям") %>
              <%= header_with_info("Маржа", tooltip: "Маржа = Пр. цены − Сумма Д") %>
              <%= header_with_info("МД %", tooltip: "Рентабельность маржинального дохода, %") %>
              <%= header_with_info("Проц.", tooltip: "Убыток проценен, если всем позициям проставлены цены или подходящий статус", align: :center) %>
              <div></div>
            </div>
            <%= render partial: "incases/report_row", collection: @incases, as: :incase, locals: { date_from: @date_from, date_to: @date_to } %>
          </div>
        </div>
        <div class="px-4 py-2 border-t border-gray-200">
          <%= render "shared/paginate", f: @incases %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
      <p>Нет данных за выбранный период.</p>
      <p class="mt-2 text-sm">Измените диапазон дат и нажмите «Применить».</p>
    </div>
  <% end %>
<% end %>
