<%= form_with model: [moysklad, mapping], local: true, class: "space-y-4" do |f| %>
  <%= render "shared/errors", object: mapping %>

  <fieldset>
    <%= f.label :source_key, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :source_key,
        options_for_select(
          OrderFieldSourceKeys::SOURCE_KEYS.map { |k, label| [label, k] },
          mapping.source_key
        ),
        { include_blank: true },
        class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
  </fieldset>

  <fieldset>
    <%= f.label :ms_attribute_href, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if @ms_attributes.present? %>
      <%= f.select :ms_attribute_href,
          options_for_select(
            @ms_attributes.map { |a| [a[:name], a[:href]] },
            mapping.ms_attribute_href
          ),
          { include_blank: true },
          class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
    <% else %>
      <%= f.text_field :ms_attribute_href,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md font-mono text-sm" %>
      <p class="text-xs text-gray-500 mt-1"><%= t("moysklad_order_field_mappings.form.attribute_href_hint") %></p>
    <% end %>
  </fieldset>

  <div class="flex justify-end">
    <%= f.submit t("actions.save"), class: "px-4 py-2 bg-violet-600 text-white rounded-md hover:bg-violet-700" %>
  </div>
<% end %>
